  return <span style={{display:"inline-flex",gap:4,alignItems:"center"}}>
    {[0,1,2].map(i=><span key={i} style={{width:6,height:6,borderRadius:"50%",background:"#f59e0b",
      animation:"bonce 1.2s infinite",animationDelay:`${i*0.2}s`}}/>)}
    <style>{`@keyframes bonce{0%,80%,100%{transform:translateY(0)}40%{transform:translateY(-6px)}}`}</style>
  </span>;
}

function Ball({ n, hot, size=36 }) {
  return <span style={{
    display:"inline-flex",alignItems:"center",justifyContent:"center",
    width:size,height:size,borderRadius:"50%",
    background:hot?"linear-gradient(135deg,#f59e0b,#ef4444)":"linear-gradient(135deg,#1e3a5f,#0f2344)",
    color:"#fff",fontWeight:700,fontSize:size>30?13:11,flexShrink:0,
    border:hot?"2px solid #fbbf24":"2px solid #2d5a8e",
    boxShadow:hot?"0 0 12px rgba(245,158,11,0.6)":"0 2px 6px rgba(0,0,0,0.4)",
  }}>{String(n).padStart(2,"0")}</span>;
}

function Card({ title, value, sub, color="#f59e0b" }) {
  return <div style={{background:"rgba(15,35,68,0.8)",border:`1px solid ${color}33`,
    borderRadius:12,padding:"16px 20px",borderLeft:`3px solid ${color}`}}>
    <div style={{color:"#8899bb",fontSize:11,textTransform:"uppercase",letterSpacing:1}}>{title}</div>
    <div style={{color,fontSize:24,fontWeight:800,fontFamily:"'Courier New',monospace",margin:"4px 0 2px"}}>{value}</div>
    {sub&&<div style={{color:"#6677aa",fontSize:11}}>{sub}</div>}
  </div>;
}

function Sec({ title, icon, children }) {
  return <div style={{background:"rgba(10,25,55,0.9)",border:"1px solid rgba(45,90,142,0.4)",
    borderRadius:16,padding:24,marginBottom:20}}>
    <h3 style={{color:"#f59e0b",margin:"0 0 18px",fontSize:15,fontWeight:700,
      fontFamily:"'Courier New',monospace",letterSpacing:1,
      display:"flex",alignItems:"center",gap:8,
      borderBottom:"1px solid rgba(245,158,11,0.2)",paddingBottom:12}}>
      <span>{icon}</span> {title}
    </h3>
    {children}
  </div>;
}

function Bar({ v, max, color="#f59e0b" }) {
  const pct = max>0?Math.round((v/max)*100):0;
  return <div style={{display:"flex",alignItems:"center",gap:8,flex:1}}>
    <div style={{flex:1,height:6,background:"rgba(255,255,255,0.07)",borderRadius:3,overflow:"hidden"}}>
      <div style={{width:`${pct}%`,height:"100%",borderRadius:3,
        background:`linear-gradient(90deg,${color},${color}88)`,transition:"width 0.6s"}}/>
    </div>
    <span style={{color:"#8899bb",fontSize:11,width:32,textAlign:"right"}}>{pct}%</span>
  </div>;
}

export default function App() {
  const [raw, setRaw] = useState(SAMPLE_DATA);
  const [days, setDays] = useState(100);
  const [res, setRes] = useState(null);
  const [summary, setSummary] = useState("");
  const [loading, setLoading] = useState(false);
  const [summaryLoading, setSummaryLoading] = useState(false);
  const [err, setErr] = useState(null);
  const [tab, setTab] = useState("frequency");
  const [xlsxInfo, setXlsxInfo] = useState("");
  const fileRef = useRef(null);

  const handleFile = useCallback((file) => {
    const reader = new FileReader();
    reader.onload = (e) => {
      try {
        const wb = XLSX.read(e.target.result, { type: "array" });
        const ws = wb.Sheets[wb.SheetNames[0]];
        const rows = XLSX.utils.sheet_to_json(ws, { header: 1, defval: "" });
        const lines = [];
        for (const row of rows) {
          // Find date cell and number cells
          let dateStr = "";
          let nums = [];
          for (const cell of row) {
            const s = String(cell).trim();
            // Try parse as date: dd/mm/yyyy or yyyy-mm-dd
            const dmY = s.match(/^(\d{1,2})[\/\-](\d{1,2})[\/\-](\d{4})$/);
            const Ymd = s.match(/^(\d{4})[\/\-](\d{1,2})[\/\-](\d{1,2})$/);
            if (dmY) {
              dateStr = `${dmY[3]}-${dmY[2].padStart(2,"0")}-${dmY[1].padStart(2,"0")}`;
            } else if (Ymd) {
              dateStr = s.slice(0,10);
            } else {
              // Extract numbers from cell (handles "04  21  25  31  41  43" style)
              const cellNums = s.split(/\s+/).map(Number).filter(n => !isNaN(n) && n > 0 && n <= 45);
              nums.push(...cellNums);
            }
          }
          if (!dateStr && nums.length === 0) continue;
          if (nums.length >= 6) {
            const label = dateStr || `Ky-${lines.length+1}`;
            lines.push(`${label}: ${nums.slice(0,6).map(n=>String(n).padStart(2,"0")).join(" ")}`);
          }
        }
        // Reverse if newest-first (check dates)
        if (lines.length >= 2) {
          const d1 = lines[0].split(":")[0].trim();
          const d2 = lines[lines.length-1].split(":")[0].trim();
          if (d1 > d2) lines.reverse();
        }
        if (lines.length === 0) {
          setXlsxInfo("⚠️ Khong doc duoc du lieu — kiem tra dinh dang file");
          return;
        }
        setRaw(lines.join("\n"));
        setDays(Math.min(lines.length, 100));
        setXlsxInfo(`✅ Da tai: ${file.name} — ${lines.length} ky quay`);
        setRes(null); setSummary("");
      } catch(err) {
        setXlsxInfo("⚠️ Loi doc file: " + err.message);
      }
    };
    reader.readAsArrayBuffer(file);
  }, []);

  const analyze = useCallback(async () => {
    setLoading(true); setErr(null); setRes(null); setSummary("");
    try {
      const stats = runAnalysis(raw, days);
      setRes(stats);
      setSummaryLoading(true);
      fetchSummary(stats).then(s => { setSummary(s); setSummaryLoading(false); });
    } catch(e) { setErr(e.message); }
    finally { setLoading(false); }
  }, [raw, days]);

  const tabs = [
    {id:"frequency",label:"Tan suat",icon:"📊"},
    {id:"gap",label:"Nhip Gap",icon:"⏱"},
    {id:"cooccurrence",label:"Cap so",icon:"🔗"},
    {id:"chi_square",label:"Chi-square",icon:"🔬"},
    {id:"monte_carlo",label:"Monte Carlo",icon:"🎲"},
  ];
  const maxF = res?.frequency?.most_frequent?.[0]?.count||1;

  return (
    <div style={{minHeight:"100vh",background:"linear-gradient(160deg,#020b1a,#041530 50%,#0a2040)",
      fontFamily:"'Segoe UI',sans-serif",color:"#c8d8f0",paddingBottom:40}}>

      {/* Header */}
      <div style={{background:"rgba(8,20,50,0.97)",borderBottom:"1px solid rgba(245,158,11,0.3)",
        padding:"18px 32px",display:"flex",alignItems:"center",justifyContent:"space-between",
        position:"sticky",top:0,zIndex:100,backdropFilter:"blur(12px)"}}>
        <div style={{display:"flex",alignItems:"center",gap:12}}>
          <span style={{fontSize:26}}>🎯</span>
          <div>
            <h1 style={{margin:0,fontSize:19,fontWeight:800,color:"#f59e0b",letterSpacing:1}}>LOTTERY ANALYZER PRO</h1>
            <div style={{color:"#4a7ab0",fontSize:10,letterSpacing:2}}>STATISTICAL & PROBABILITY ENGINE</div>
          </div>
        </div>
        <div style={{background:"rgba(245,158,11,0.1)",border:"1px solid rgba(245,158,11,0.3)",
          borderRadius:8,padding:"5px 12px",color:"#f59e0b",fontSize:10,fontFamily:"monospace",letterSpacing:1}}>
          ✦ CLAUDE AI
        </div>
      </div>

      <div style={{maxWidth:1100,margin:"0 auto",padding:"28px 20px 0"}}>

        {/* Input */}
        <div style={{background:"rgba(10,25,55,0.9)",border:"1px solid rgba(45,90,142,0.4)",
          borderRadius:16,padding:24,marginBottom:24}}>

          {/* File upload zone */}
          <div
            onDragOver={e=>{e.preventDefault();e.currentTarget.style.borderColor="#f59e0b";}}
            onDragLeave={e=>{e.currentTarget.style.borderColor="rgba(45,90,142,0.5)";}}
            onDrop={e=>{e.preventDefault();e.currentTarget.style.borderColor="rgba(45,90,142,0.5)";const f=e.dataTransfer.files[0];if(f)handleFile(f);}}
            onClick={()=>fileRef.current.click()}
            style={{border:"2px dashed rgba(45,90,142,0.5)",borderRadius:12,padding:"16px 20px",
              marginBottom:18,cursor:"pointer",display:"flex",alignItems:"center",gap:14,
              transition:"border-color 0.2s",background:"rgba(5,15,40,0.4)"}}>
            <span style={{fontSize:28}}>📂</span>
            <div style={{flex:1}}>
              <div style={{color:xlsxInfo?"#a0e8a0":"#a0c0e8",fontSize:13,fontWeight:600}}>
                {xlsxInfo || "Kéo thả file .xlsx vào đây hoặc click để chọn"}
              </div>
              <div style={{color:"#4a7ab0",fontSize:11,marginTop:3}}>
                File Excel: cột Ngày Mở Thưởng + cột Kết Quả — tự động nhận diện
              </div>
            </div>
            <input ref={fileRef} type="file" accept=".xlsx,.xls"
              onChange={e=>e.target.files[0]&&handleFile(e.target.files[0])}
              style={{display:"none"}}/>
          </div>

          <div style={{display:"flex",gap:20,flexWrap:"wrap"}}>
            <div style={{flex:"2 1 300px"}}>
              <label style={{color:"#8899bb",fontSize:11,letterSpacing:1,display:"block",marginBottom:8}}>
                📋 DU LIEU (tu dong dien sau khi upload — hoac nhap tay: YYYY-MM-DD: n1 n2 ...)
              </label>
              <textarea value={raw} onChange={e=>setRaw(e.target.value)} rows={8}
                style={{width:"100%",background:"rgba(5,15,40,0.9)",border:"1px solid rgba(45,90,142,0.5)",
                  borderRadius:10,color:"#a0c0e8",fontSize:12,fontFamily:"monospace",
                  padding:14,resize:"vertical",outline:"none",boxSizing:"border-box",lineHeight:1.6}}/>
            </div>
            <div style={{flex:"0 1 200px",display:"flex",flexDirection:"column",gap:16}}>
              <div>
                <label style={{color:"#8899bb",fontSize:11,letterSpacing:1,display:"block",marginBottom:8}}>
                  📅 SO KY PHAN TICH
                </label>
                <input type="number" value={days} onChange={e=>setDays(Math.max(7,+e.target.value))}
                  min={7} max={9999}
                  style={{width:"100%",background:"rgba(5,15,40,0.9)",border:"1px solid rgba(45,90,142,0.5)",
                    borderRadius:10,color:"#f59e0b",fontSize:22,fontWeight:800,fontFamily:"monospace",
                    padding:"10px 14px",outline:"none",boxSizing:"border-box",textAlign:"center"}}/>
                <div style={{color:"#4a7ab0",fontSize:10,marginTop:4,textAlign:"center"}}>ky quay gan nhat</div>
              </div>
              <button onClick={analyze} disabled={loading||!raw.trim()}
                style={{background:loading?"rgba(245,158,11,0.15)":"linear-gradient(135deg,#f59e0b,#d97706)",
                  border:"none",borderRadius:12,color:loading?"#f59e0b":"#0a1a35",
                  fontWeight:800,fontSize:14,padding:"16px 20px",
                  cursor:loading?"default":"pointer",letterSpacing:1,
                  display:"flex",alignItems:"center",justifyContent:"center",gap:8,
                  boxShadow:loading?"none":"0 4px 20px rgba(245,158,11,0.35)",transition:"all 0.2s"}}>
                {loading?<><Dots/> Dang tinh...</>:"🚀 PHAN TICH NGAY"}
              </button>
            </div>
          </div>
        </div>

        {err&&<div style={{background:"rgba(239,68,68,0.1)",border:"1px solid rgba(239,68,68,0.4)",
          borderRadius:12,padding:"14px 20px",color:"#f87171",marginBottom:20,fontSize:13}}>⚠️ {err}</div>}

        {res&&<>
          {/* Stat cards */}
          <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(140px,1fr))",gap:14,marginBottom:22}}>
            <Card title="Ky phan tich" value={res.days_analyzed} sub="ky quay" color="#f59e0b"/>
            <Card title="So nong nhat" value={String(res.frequency.most_frequent[0]?.number).padStart(2,"0")}
              sub={`${res.frequency.most_frequent[0]?.count} lan`} color="#ef4444"/>
            <Card title="P-value" value={res.chi_square.p_value}
              sub={res.chi_square.p_value>0.05?"Ngau nhien":"Co quy luat?"} color="#10b981"/>
            <Card title="Monte Carlo" value="10,000" sub="lan mo phong" color="#8b5cf6"/>
          </div>

          {/* AI Summary */}
          <div style={{background:"linear-gradient(135deg,rgba(245,158,11,0.08),rgba(239,68,68,0.05))",
            border:"1px solid rgba(245,158,11,0.25)",borderRadius:14,
            padding:"16px 22px",marginBottom:22,borderLeft:"3px solid #f59e0b"}}>
            <div style={{color:"#f59e0b",fontSize:11,letterSpacing:1,marginBottom:6}}>💡 NHAN XET CHUYEN GIA (Claude AI)</div>
            {summaryLoading
              ?<div style={{color:"#6677aa",fontSize:13}}>Dang tai nhan xet <Dots/></div>
              :<p style={{margin:0,color:"#c8d8f0",fontSize:13,lineHeight:1.7}}>{summary||"Nhan xet se hien sau khi tai xong."}</p>}
          </div>

          {/* Tabs */}
          <div style={{display:"flex",gap:8,marginBottom:20,flexWrap:"wrap"}}>
            {tabs.map(t=><button key={t.id} onClick={()=>setTab(t.id)}
              style={{background:tab===t.id?"rgba(245,158,11,0.2)":"rgba(15,35,68,0.6)",
                border:`1px solid ${tab===t.id?"rgba(245,158,11,0.6)":"rgba(45,90,142,0.4)"}`,
                borderRadius:8,color:tab===t.id?"#f59e0b":"#6677aa",
                padding:"8px 16px",cursor:"pointer",fontSize:12,fontWeight:600,
                display:"flex",alignItems:"center",gap:6,transition:"all 0.15s"}}>
              {t.icon} {t.label}
            </button>)}
          </div>

          {/* Frequency */}
          {tab==="frequency"&&<div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:20}}>
            <Sec title="TOP 10 SO NONG NHAT" icon="🔥">
              {res.frequency.most_frequent.map((item,i)=><div key={i}
                style={{display:"flex",alignItems:"center",gap:10,marginBottom:10}}>
                <span style={{color:"#4a7ab0",fontSize:11,width:18}}>#{i+1}</span>
                <Ball n={item.number} hot={i<3}/>
                <Bar v={item.count} max={maxF} color={i<3?"#ef4444":"#f59e0b"}/>
                <span style={{color:"#8899bb",fontSize:11,width:40,textAlign:"right"}}>{item.count}x</span>
              </div>)}
            </Sec>
            <Sec title="TOP 10 SO LANH NHAT" icon="❄️">
              {res.frequency.least_frequent.map((item,i)=><div key={i}
                style={{display:"flex",alignItems:"center",gap:10,marginBottom:10}}>
                <span style={{color:"#4a7ab0",fontSize:11,width:18}}>#{i+1}</span>
                <Ball n={item.number}/>
                <Bar v={item.count} max={maxF} color="#4a7ab0"/>
                <span style={{color:"#8899bb",fontSize:11,width:40,textAlign:"right"}}>{item.count}x</span>
              </div>)}
            </Sec>
          </div>}

          {/* Gap */}
          {tab==="gap"&&<Sec title="PHAN TICH NHIP — GAP ANALYSIS" icon="⏱">
            <p style={{color:"#6677aa",fontSize:12,margin:"0 0 16px"}}>
              Khoang cach trung binh (so ky) giua cac lan xuat hien. Gap nho = xuat hien deu dan hon.
            </p>
            <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(210px,1fr))",gap:12}}>
              {res.gap.map((item,i)=><div key={i}
                style={{background:"rgba(5,15,40,0.7)",border:"1px solid rgba(45,90,142,0.3)",
                  borderRadius:10,padding:"14px 16px",display:"flex",alignItems:"center",gap:12}}>
                <Ball n={item.number} hot={item.avg_gap<=3}/>
                <div style={{flex:1}}>
                  <div style={{color:item.avg_gap<=3?"#f59e0b":"#c8d8f0",fontSize:20,fontWeight:800,fontFamily:"monospace"}}>
                    {item.avg_gap} <span style={{fontSize:11,color:"#6677aa"}}>ky</span>
                  </div>
                  <div style={{color:"#6677aa",fontSize:10}}>Xuat hien {item.appearances} lan</div>
                  <div style={{color:"#4a7ab0",fontSize:10}}>
                    {item.last_seen} {item.days_since>0?`(${item.days_since} ky truoc)`:"(ky cuoi)"}
                  </div>
                </div>
              </div>)}
            </div>
          </Sec>}

          {/* Cooccurrence */}
          {tab==="cooccurrence"&&<Sec title="PHAN TICH CAP SO — CO-OCCURRENCE" icon="🔗">
            {res.cooccurrence.map((item,i)=><div key={i}
              style={{display:"flex",alignItems:"center",gap:14,padding:"12px 16px",marginBottom:8,
                background:"rgba(5,15,40,0.5)",borderRadius:10,border:"1px solid rgba(45,90,142,0.25)"}}>
              <span style={{color:"#4a7ab0",fontSize:12,width:22,fontWeight:700}}>#{i+1}</span>
              <div style={{display:"flex",gap:6}}>{item.pair.map((n,j)=><Ball key={j} n={n} hot={i<3}/>)}</div>
              <Bar v={item.count} max={res.cooccurrence[0]?.count||1} color={i<3?"#f59e0b":"#4a7ab0"}/>
              <div style={{textAlign:"right",flexShrink:0}}>
                <div style={{color:i<3?"#f59e0b":"#8b5cf6",fontSize:15,fontWeight:800,fontFamily:"monospace"}}>{item.count}x</div>
                <div style={{color:"#4a7ab0",fontSize:10}}>{item.frequency}%</div>
              </div>
            </div>)}
          </Sec>}

          {/* Chi-square */}
          {tab==="chi_square"&&<Sec title="KIEM DINH CHI-SQUARE — TINH NGAU NHIEN" icon="🔬">
            <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(160px,1fr))",gap:16,marginBottom:20}}>
              <Card title="Chi2 Statistic" value={res.chi_square.statistic} color="#8b5cf6"/>
              <Card title="P-value" value={res.chi_square.p_value} color="#10b981"/>
              <Card title="Bac tu do (df)" value={res.chi_square.degrees_of_freedom} color="#f59e0b"/>
            </div>
            <div style={{
              background:res.chi_square.p_value>0.05?"rgba(16,185,129,0.08)":"rgba(239,68,68,0.08)",
              border:`1px solid ${res.chi_square.p_value>0.05?"rgba(16,185,129,0.3)":"rgba(239,68,68,0.3)"}`,
              borderRadius:12,padding:"16px 20px",
              borderLeft:`3px solid ${res.chi_square.p_value>0.05?"#10b981":"#ef4444"}`}}>
              <div style={{fontSize:20,marginBottom:8}}>{res.chi_square.p_value>0.05?"✅":"⚠️"} KET LUAN</div>
              <p style={{margin:0,color:"#c8d8f0",fontSize:13,lineHeight:1.7}}>{res.chi_square.conclusion}</p>
            </div>
            <div style={{marginTop:16,padding:"12px 16px",background:"rgba(139,92,246,0.08)",borderRadius:10,fontSize:12,color:"#8b7acc"}}>
              <strong>Cach doc:</strong> P-value &gt; 0.05 → phan phoi deu, ngau nhien. P-value &lt; 0.05 → co su phan phoi khong deu dang ke.
            </div>
          </Sec>}

          {/* Monte Carlo */}
          {tab==="monte_carlo"&&<Sec title="MO PHONG MONTE CARLO — 10,000 LAN" icon="🎲">
            <div style={{background:"rgba(139,92,246,0.08)",border:"1px solid rgba(139,92,246,0.25)",
              borderRadius:10,padding:"10px 16px",marginBottom:20,fontSize:12,color:"#8b7acc"}}>
              ⚠️ Ket qua mo phong dua tren phan phoi tan suat lich su. Xo so la tro choi hoan toan ngau nhien.
            </div>
            {res.monte_carlo.map((item,i)=><div key={i} style={{
              background:i===0?"linear-gradient(135deg,rgba(245,158,11,0.12),rgba(239,68,68,0.08))":"rgba(5,15,40,0.5)",
              border:`1px solid ${i===0?"rgba(245,158,11,0.45)":"rgba(45,90,142,0.25)"}`,
              borderRadius:12,padding:"16px 20px",marginBottom:12}}>
              <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",flexWrap:"wrap",gap:12}}>
                <div style={{display:"flex",alignItems:"center",gap:12}}>
                  <div style={{width:32,height:32,borderRadius:"50%",
                    background:i===0?"linear-gradient(135deg,#f59e0b,#ef4444)":"rgba(45,90,142,0.4)",
                    display:"flex",alignItems:"center",justifyContent:"center",
                    color:"#fff",fontWeight:800,fontSize:13,flexShrink:0}}>#{item.rank}</div>
                  <div style={{display:"flex",gap:6,flexWrap:"wrap"}}>
                    {item.numbers.map((n,j)=><Ball key={j} n={n} hot={i===0}/>)}
                  </div>
                </div>
                <div style={{textAlign:"right"}}>
                  <div style={{color:i===0?"#f59e0b":"#8b5cf6",fontSize:18,fontWeight:800,fontFamily:"monospace"}}>
                    {item.probability}%
                  </div>
                  <div style={{color:"#4a7ab0",fontSize:10}}>{item.appearances} / 10,000 lan</div>
                </div>
              </div>
            </div>)}
          </Sec>}
        </>}

        {!res&&!loading&&<div style={{textAlign:"center",padding:"60px 20px",color:"#2d5a8e"}}>
          <div style={{fontSize:56,marginBottom:16}}>🎯</div>
          <div style={{fontSize:15,fontWeight:600,color:"#4a7ab0",marginBottom:6}}>Nhap du lieu va nhan Phan Tich Ngay</div>
          <div style={{fontSize:12}}>Du lieu mau 30 ky da duoc dien san</div>
        </div>}
      </div>
    </div>
  );
}
