// ── Analytics Engine (pure JS, no AI) ──────────────────────────────────────
function parseDraws(raw, days) {
  const lines = raw.trim().split("\n").filter(l => l.trim());
  return lines.slice(-days).map((line, idx) => {
    const colonIdx = line.indexOf(":");
    const date = colonIdx > -1 ? line.slice(0, colonIdx).trim() : `Ky ${idx+1}`;
    const numStr = colonIdx > -1 ? line.slice(colonIdx+1) : line;
    const nums = numStr.trim().split(/\s+/).map(Number).filter(n => !isNaN(n) && n > 0);
    return { date, nums, idx };
  }).filter(d => d.nums.length > 0);
}

function computeFrequency(draws) {
  const freq = {};
  draws.forEach(({ nums }) => nums.forEach(n => { freq[n] = (freq[n]||0)+1; }));
  const total = draws.length;
  const arr = Object.entries(freq).map(([n, c]) => ({
    number: +n, count: c, percentage: +((c/total)*100).toFixed(1)
  }));
  const desc = [...arr].sort((a,b) => b.count - a.count);
  return { most_frequent: desc.slice(0,10), least_frequent: [...desc].reverse().slice(0,10) };
}

function computeGap(draws) {
  const occ = {};
  draws.forEach(({ nums, idx }) => nums.forEach(n => {
    if (!occ[n]) occ[n] = [];
    occ[n].push(idx);
  }));
  return Object.entries(occ).map(([n, idxs]) => {
    const gaps = idxs.slice(1).map((v,i) => v - idxs[i]);
    const avg_gap = gaps.length ? +(gaps.reduce((a,b)=>a+b,0)/gaps.length).toFixed(1) : draws.length;
    const lastIdx = idxs[idxs.length-1];
    return {
      number: +n, avg_gap, appearances: idxs.length,
      last_seen: draws[lastIdx]?.date,
      days_since: draws.length - 1 - lastIdx
    };
  }).sort((a,b) => a.avg_gap - b.avg_gap).slice(0,12);
}

function computeCooccurrence(draws) {
  const pairs = {};
  draws.forEach(({ nums }) => {
    for (let i=0; i<nums.length; i++)
      for (let j=i+1; j<nums.length; j++) {
        const key = [nums[i],nums[j]].sort((a,b)=>a-b).join(",");
        pairs[key] = (pairs[key]||0)+1;
      }
  });
  return Object.entries(pairs)
    .map(([k,c]) => ({ pair: k.split(",").map(Number), count: c, frequency: +((c/draws.length)*100).toFixed(1) }))
    .sort((a,b) => b.count - a.count).slice(0,10);
}

function erf(x) {
  const t = 1/(1+0.3275911*Math.abs(x));
  const p = t*(0.254829592+t*(-0.284496736+t*(1.421413741+t*(-1.453152027+t*1.061405429))));
  const r = 1 - p*Math.exp(-x*x);
  return x>=0 ? r : -r;
}

function computeChiSquare(draws) {
  const freq = {};
  let total = 0;
  draws.forEach(({ nums }) => nums.forEach(n => { freq[n]=(freq[n]||0)+1; total++; }));
  const nums = Object.keys(freq);
  const k = nums.length;
  const expected = total/k;
  const chi2 = nums.reduce((s,n) => s + Math.pow(freq[n]-expected,2)/expected, 0);
  const df = k-1;
  const x = chi2/df;
  const z = (Math.pow(x,1/3) - (1-2/(9*df))) / Math.sqrt(2/(9*df));
  const p_value = Math.max(0.0001, Math.min(0.9999, +(1-0.5*(1+erf(z/Math.sqrt(2)))).toFixed(4)));
  const conclusion = p_value > 0.05
    ? `P-value = ${p_value} > 0.05: Khong co bang chung thong ke ve quy luat phi tu nhien. Du lieu phu hop phan phoi ngau nhien.`
    : `P-value = ${p_value} < 0.05: Co dau hieu phan phoi khong deu. Can them du lieu de ket luan.`;
  return { statistic: +chi2.toFixed(3), p_value, degrees_of_freedom: df, conclusion };
}

function computeMonteCarlo(draws, N=10000) {
  const freq = {};
  draws.forEach(({ nums }) => nums.forEach(n => { freq[n]=(freq[n]||0)+1; }));
  const nums = Object.keys(freq).map(Number);
  const weights = nums.map(n => freq[n]);
  const total = weights.reduce((a,b)=>a+b,0);
  const cum = [];
  let s=0;
  weights.forEach(w => { s+=w/total; cum.push(s); });
  const pick = () => {
    const r = Math.random();
    for (let i=0; i<cum.length; i++) if (r<=cum[i]) return nums[i];
    return nums[nums.length-1];
  };
  const pickSet = () => {
    const chosen = new Set();
    let tries=0;
    while (chosen.size<6 && tries++<100) chosen.add(pick());
    return [...chosen].sort((a,b)=>a-b);
  };
  const counts = {};
  for (let i=0; i<N; i++) {
    const k = pickSet().join(",");
    counts[k] = (counts[k]||0)+1;
  }
  return Object.entries(counts)
    .sort((a,b)=>b[1]-a[1]).slice(0,5)
    .map(([k,c],i) => ({
      rank:i+1, numbers:k.split(",").map(Number),
      appearances:c, probability: +((c/N)*100).toFixed(3)
    }));
}

function runAnalysis(raw, days) {
  const draws = parseDraws(raw, days);
  if (!draws.length) throw new Error("Khong parse duoc du lieu. Kiem tra dinh dang: YYYY-MM-DD: n1 n2 n3...");
  return {
    days_analyzed: draws.length,
    frequency: computeFrequency(draws),
    gap: computeGap(draws),
    cooccurrence: computeCooccurrence(draws),
    chi_square: computeChiSquare(draws),
    monte_carlo: computeMonteCarlo(draws),
  };
}

async function fetchSummary(stats) {
  const top3 = stats.frequency.most_frequent.slice(0,3).map(x=>x.number).join(", ");
  const cold3 = stats.frequency.least_frequent.slice(0,3).map(x=>x.number).join(", ");
  const topPair = stats.cooccurrence[0]?.pair?.join(" va ") || "N/A";
  const prompt = `Ban la chuyen gia thong ke xo so. Nhan xet ngan (3-4 cau) bang tieng Viet ve:
- ${stats.days_analyzed} ky phan tich
- So nong: ${top3} | So lanh: ${cold3}
- Cap so xuat hien nhieu nhat: ${topPair} (${stats.cooccurrence[0]?.count} lan)
- Chi-square p-value: ${stats.chi_square.p_value} (${stats.chi_square.p_value>0.05?"ngau nhien":"co quy luat?"})
Chi tra ve doan van nhan xet.`;
  try {
    const res = await fetch("https://api.anthropic.com/v1/messages", {
      method:"POST",
      headers:{"Content-Type":"application/json"},
      body:JSON.stringify({
        model:"claude-sonnet-4-20250514", max_tokens:400,
        messages:[{role:"user",content:prompt}]
      })
    });
    const d = await res.json();
    return d.content?.[0]?.text || "";
  } catch { return ""; }
}

